# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration (Prisma)
# Example for SQLite (local dev)
DATABASE_URL="file:./dev.db"

# Authentication
# Secret key used for signing JWT tokens. Use a strong, random string in production.
JWT_SECRET=your_super_secret_jwt_key_here

# AI / LLM Configuration
# Set the provider to either "gemini" or "openai"
LLM_PROVIDER=gemini

# Provide the corresponding API key
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Email Notification Configuration (SMTP)
# If left blank, the system will automatically create and use an Ethereal Email test account for development.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM="Rent & Flatmate Finder" <noreply@flatmatefinder.com>
